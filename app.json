{
  "expo": {
    "name": "FIELD TRACK",
    "slug": "field-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/staffTrackLogo.png",
    "scheme": "fieldtrackapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/staffTrackLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          },
          "autoHide": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FIELD TRACK to use your location for tracking field staff.",
          "locationAlwaysPermission": "Allow FIELD TRACK to use your location in background for continuous monitoring.",
          "locationWhenInUsePermission": "Allow FIELD TRACK to use your location.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],

    "android": {
      "backgroundColor": "#ffffff",
      "predictiveBackGestureEnabled": false,
      "package": "com.gautam1008.fieldtrack",

      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK"
      ],

      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDVl4s2zlYODWTIpEfzYePa_hj5nrWksuE"
        }
      },

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/staffTrackLogo.png",
        "backgroundColor": "#ffffff"
      }
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gautam1008.fieldtrack",

      "config": {
        "googleMapsApiKey": "AIzaSyDVl4s2zlYODWTIpEfzYePa_hj5nrWksuE"
      },

      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSLocationWhenInUseUsageDescription": "This app needs your location to track field staff.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app tracks location in background for field monitoring.",
        "NSLocationAlwaysUsageDescription": "Location is used to monitor field activity."
      }
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/staffTrackLogo.png"
    },

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "e78f6d86-da99-4130-8d49-4017fd05aacc"
      }
    }
  }
}